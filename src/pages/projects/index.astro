---
import Card from '../../components/Card.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Tag from '../../components/Tag.astro';
import { loadProjectCards } from '../../lib/project-feed';
import MainLayout from '../../layouts/MainLayout.astro';

const projects = await loadProjectCards();

const categoryLabel = {
	ai: 'AI',
	security: 'Security',
	tooling: 'Tooling',
	research: 'Research',
} as const;
---

<MainLayout title="Projects · dkx" description="项目列表，覆盖 AI、安全、工具链与研究导向的工程实践。">
	<section class="space-y-6">
		<SectionHeading align="start">Projects</SectionHeading>
		<div class="space-y-3">
			<h1 class="text-4xl font-semibold tracking-tight text-graphite-950 md:text-5xl">项目列表</h1>
			<p class="max-w-3xl text-lg leading-8 text-slate-600">
				公开展示当前项目、状态、技术栈与入口链接，优先读取 GitHub 同步结果，并兼容 <code>src/content/projects/</code> 本地内容。
			</p>
		</div>
	</section>

	<section class="mt-8 grid gap-5 lg:grid-cols-2">
		{projects.map((project) => (
			<Card class="flex h-full flex-col gap-5">
				<div class="meta-row">
					<Tag>{project.status}</Tag>
					<Tag>{categoryLabel[project.category]}</Tag>
					<FormattedDate date={project.updatedDate ?? project.publishedDate} />
				</div>
				<div class="space-y-3">
					<h2 class="text-2xl font-semibold tracking-tight text-graphite-950">{project.title}</h2>
					<p class="text-sm leading-7 text-slate-600">{project.summary}</p>
				</div>
				<div class="flex flex-wrap gap-2">
					{project.stack.map((item) => <Tag>{item}</Tag>)}
				</div>
				<div class="meta-row mt-auto border-t border-slate-200 pt-4">
					{project.github && (
						<span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-slate-500">
							★ {project.github.stars} / Forks {project.github.forks}
						</span>
					)}
					{project.liveUrl && (
						<a href={project.liveUrl} target="_blank" rel="noreferrer" class="no-underline hover:text-graphite-950">
							Live
						</a>
					)}
					{project.repoUrl && (
						<a href={project.repoUrl} target="_blank" rel="noreferrer" class="no-underline hover:text-graphite-950">
							Repository
						</a>
					)}
				</div>
			</Card>
		))}
	</section>
</MainLayout>
