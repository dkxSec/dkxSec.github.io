---
import { getCollection } from 'astro:content';
import Card from '../../components/Card.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Tag from '../../components/Tag.astro';
import MainLayout from '../../layouts/MainLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<MainLayout title="Posts · dkx" description="技术文章列表，记录工程实现、站点结构与长期研究笔记。">
	<section class="space-y-6">
		<SectionHeading align="start">Posts</SectionHeading>
		<div class="space-y-3">
			<h1 class="text-4xl font-semibold tracking-tight text-graphite-950 md:text-5xl">技术文章</h1>
			<p class="max-w-3xl text-lg leading-8 text-slate-600">
				正式文章列表，读取 <code>src/content/posts/</code>，默认按发布日期倒序展示并自动跳过草稿。
			</p>
		</div>
	</section>

	<section class="mt-8 grid gap-4">
		{posts.map((post) => (
			<article class="card transition hover:border-blue-soft hover:bg-slate-100/[0.48]">
				<a href={`/posts/${post.id}/`} class="grid gap-4 no-underline md:grid-cols-[minmax(0,1fr)_10rem] md:items-end">
					<div class="space-y-3">
						<div class="flex flex-wrap gap-2">
							{post.data.tags.map((tag) => <Tag>{tag}</Tag>)}
						</div>
						<h2 class="text-2xl font-semibold tracking-tight text-graphite-950">{post.data.title}</h2>
						<p class="text-sm leading-7 text-slate-600">{post.data.description}</p>
					</div>
					<div class="space-y-2 text-sm text-slate-400 md:text-right">
						<FormattedDate date={post.data.date} />
						<p class="font-mono text-[0.78rem] uppercase tracking-[0.18em] text-slate-500">{post.data.readingTime}</p>
					</div>
				</a>
			</article>
		))}
	</section>
</MainLayout>
