---
import { getCollection, getEntry } from 'astro:content';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Tag from '../components/Tag.astro';
import { loadProjectCards } from '../lib/project-feed';
import MainLayout from '../layouts/MainLayout.astro';

const site = await getEntry('site', 'home');

if (!site) {
	throw new Error('Missing site/home content entry.');
}

const allProjects = await loadProjectCards();
const projects = allProjects
	.filter((project) => project.featured || site.data.featuredProjects.includes(project.id))
	.slice(0, 3);
const posts = (await getCollection('posts', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const categoryLabel: Record<string, string> = {
	ai: 'AI',
	security: 'Security',
	tooling: 'Tooling',
	research: 'Research',
};

const metrics = [
	{
		label: 'Featured Projects',
		value: String(allProjects.length).padStart(2, '0'),
		note: '精选项目数',
		description: '当前首页展示的代表性项目入口',
	},
	{
		label: 'Published Posts',
		value: String(allPosts.length).padStart(2, '0'),
		note: '已发布文章数',
		description: '当前公开输出的文章与技术记录',
	},
	{
		label: 'Focus Tracks',
		value: String(site.data.focusAreas.length).padStart(2, '0'),
		note: '重点方向数',
		description: '长期关注的研究与工程主题范围',
	},
];

const skillHighlights = site.data.skills.map((group) => ({
	...group,
	preview: group.items.slice(0, 3),
}));
---

<MainLayout title={`${site.data.name} · ${site.data.title}`} description={site.data.description} contentClass="max-w-none">
	<section class="homepage-hero surface-panel overflow-hidden motion-section">
		<div class="hero-grid grid gap-10 px-6 py-8 md:px-8 md:py-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(20rem,27rem)] lg:items-center">
			<div class="hero-copy space-y-7">
				<SectionHeading align="start">Research-minded homepage</SectionHeading>
				<div class="space-y-5">
					<h1 class="text-balance max-w-5xl text-5xl font-semibold tracking-tight text-graphite-950 md:text-6xl">
					{site.data.heroTitle}
					</h1>
					<p class="text-lg font-medium text-blue-deep">{site.data.heroTagline}</p>
					<p class="max-w-3xl text-lg leading-8 text-slate-600">{site.data.description}</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<Button href="/projects">查看项目</Button>
					<Button href="/posts" variant="secondary">阅读文章</Button>
				</div>
				<div class="flex flex-wrap gap-2">
					{site.data.focusAreas.map((item) => <Tag>{item}</Tag>)}
				</div>
				<div class="grid gap-4 pt-4 md:grid-cols-3">
					{metrics.map((metric) => (
						<div class="metric-card rounded-[1.5rem] border border-slate-200 bg-white/86 px-4 py-4">
							<div class="flex flex-wrap items-center justify-between gap-2">
								<p class="font-mono text-[0.72rem] uppercase tracking-[0.24em] text-slate-500">{metric.label}</p>
								{metric.note && (
									<span class="metric-card__note">{metric.note}</span>
								)}
							</div>
							<p class="mt-3 text-3xl font-semibold tracking-tight text-graphite-950">{metric.value}</p>
							{metric.description && (
								<p class="mt-2 text-sm leading-6 text-slate-500">{metric.description}</p>
							)}
						</div>
					))}
				</div>
			</div>

			<div class="hero-aside space-y-5">
				<div class="code-panel">
					<div class="code-panel__top">
						<div class="code-panel__dots" aria-hidden="true">
							<span></span>
							<span></span>
							<span></span>
						</div>
						<span class="code-panel__file">builder.py</span>
					</div>
					<pre class="code-panel__body"><code>{`class Builder:
    def __init__(self):
        self.goal = "Research -> Build -> Impact"
        self.focus = ["AI", "Security", "Systems"]

    def build(self):
        while True:
            learn()
            build()
            share()
            improve()`}</code></pre>
				</div>
				<Card as="section" class="hero-profile space-y-5 bg-slate-100/70">
					<div>
						<p class="eyebrow">Profile</p>
						<h2 class="mt-3 text-3xl font-semibold tracking-tight text-graphite-950">{site.data.name}</h2>
						<p class="mt-2 text-sm leading-7 text-slate-600">{site.data.subtitle}</p>
					</div>
					<div class="grid gap-3 border-t border-slate-200 pt-5 text-sm text-slate-600">
						{site.data.socialLinks.map((link) => (
							<a href={link.url} target="_blank" rel="noreferrer" class="no-underline hover:text-graphite-950">
								{link.label}
							</a>
						))}
					</div>
				</Card>
			</div>
		</div>
	</section>

	<section class="mt-18 motion-section">
		<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
			<SectionHeading>Featured Projects</SectionHeading>
			<a href="/projects" class="section-more-link no-underline">
				查看全部项目
			</a>
		</div>
		<div class="mt-6 grid gap-5 lg:grid-cols-3">
			{projects.map((project) => (
				<Card class="project-card flex h-full flex-col gap-5">
					<div class="project-card__icon" aria-hidden="true">
						<span>{project.title.slice(0, 2).toUpperCase()}</span>
					</div>
					<div class="space-y-3">
						<div class="flex items-center justify-between gap-3">
							<p class="eyebrow">{categoryLabel[project.category] ?? project.category}</p>
							<span class="rounded-full bg-slate-100 px-3 py-1 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-slate-500">
								{project.status}
							</span>
						</div>
						<h2 class="text-2xl font-semibold tracking-tight text-graphite-950">{project.title}</h2>
						<p class="text-sm leading-7 text-slate-600">{project.summary}</p>
					</div>
					<div class="flex flex-wrap gap-2">
						{project.stack.map((item) => <Tag>{item}</Tag>)}
					</div>
					<div class="meta-row mt-auto border-t border-slate-200 pt-4">
						<FormattedDate date={project.updatedDate ?? project.publishedDate} />
						{project.github && (
							<span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-slate-500">
								★ {project.github.stars}
							</span>
						)}
						{project.repoUrl && (
							<a href={project.repoUrl} target="_blank" rel="noreferrer" class="no-underline hover:text-graphite-950">
								Repository
							</a>
						)}
					</div>
				</Card>
			))}
		</div>
	</section>

	<section class="mt-18 motion-section">
		<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
			<SectionHeading>Latest Writing</SectionHeading>
			<a href="/posts" class="section-more-link no-underline">
				查看全部文章
			</a>
		</div>
		<div class="mt-6 grid gap-4">
			{posts.map((post, index) => (
				<Card
					as="a"
					href={`/posts/${post.id}/`}
					class="writing-card grid gap-5 no-underline transition hover:-translate-y-0.5 hover:border-blue-soft md:grid-cols-[12rem_minmax(0,1fr)_9rem] md:items-center"
				>
					<div class="writing-card__visual" data-visual={index + 1}>
						<div class="writing-card__grid"></div>
						<div class="writing-card__frame">
							<span></span>
							<span></span>
							<span></span>
						</div>
					</div>
					<div class="space-y-3">
						<div class="flex flex-wrap gap-2">
							{post.data.tags.map((tag) => <Tag>{tag}</Tag>)}
						</div>
						<h2 class="text-2xl font-semibold tracking-tight text-graphite-950">{post.data.title}</h2>
						<p class="text-sm leading-7 text-slate-600">{post.data.description}</p>
					</div>
					<div class="space-y-3 border-slate-200 text-sm text-slate-500 md:border-l md:pl-6">
						<FormattedDate date={post.data.date} />
						<p class="font-mono text-[0.78rem] uppercase tracking-[0.18em] text-slate-500">{post.data.readingTime}</p>
						<span class="inline-flex items-center gap-2 font-medium text-blue-deep">
							阅读全文
							<span aria-hidden="true">→</span>
						</span>
					</div>
				</Card>
			))}
		</div>
	</section>

	<section class="mt-18 motion-section">
		<SectionHeading>Skill Matrix</SectionHeading>
		<div class="mt-6">
			<div class="skill-board overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_18px_42px_rgba(28,43,67,0.06)]">
				<div class="grid gap-px bg-slate-200 lg:grid-cols-4">
					{skillHighlights.map((group) => (
						<div class="skill-column bg-white px-6 py-6">
							<p class="font-mono text-[0.76rem] uppercase tracking-[0.24em] text-blue-deep">{group.category}</p>
							<ul class="mt-5 space-y-3">
								{group.items.map((item, itemIndex) => (
									<li class="flex items-center justify-between gap-3 text-sm text-slate-600">
										<span>{item}</span>
										<span class="skill-dots" aria-hidden="true" data-level={Math.max(3, 5 - itemIndex)}>
											<i></i><i></i><i></i><i></i><i></i>
										</span>
									</li>
								))}
							</ul>
							<p class="mt-6 text-xs leading-6 text-slate-500">
								{group.preview.join(' / ')}
							</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>
</MainLayout>

<style>
	.mt-18 {
		margin-top: 4.5rem;
	}

	.homepage-hero {
		position: relative;
		border-radius: 2rem;
	}

	.homepage-hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(148, 163, 184, 0.12) 1px, transparent 1px),
			linear-gradient(90deg, rgba(148, 163, 184, 0.12) 1px, transparent 1px);
		background-size: 2.75rem 2.75rem;
		mask-image: radial-gradient(circle at center, black 42%, transparent 92%);
		pointer-events: none;
		animation: grid-drift 22s linear infinite;
		will-change: transform;
	}

	.homepage-hero::after {
		content: "";
		position: absolute;
		inset: auto -12% -28% auto;
		width: 24rem;
		height: 24rem;
		border-radius: 9999px;
		background:
			radial-gradient(circle, rgba(84, 121, 179, 0.16) 0%, rgba(84, 121, 179, 0.08) 34%, transparent 72%);
		filter: blur(18px);
		pointer-events: none;
		animation: orb-shift 16s ease-in-out infinite alternate;
	}

	.hero-grid {
		position: relative;
		z-index: 1;
	}

	.hero-copy,
	.hero-aside,
	.motion-section {
		animation: section-rise 0.9s cubic-bezier(0.2, 0.8, 0.2, 1) both;
	}

	.hero-aside {
		animation-delay: 0.14s;
	}

	.motion-section:nth-of-type(2) {
		animation-delay: 0.12s;
	}

	.motion-section:nth-of-type(3) {
		animation-delay: 0.2s;
	}

	.motion-section:nth-of-type(4) {
		animation-delay: 0.28s;
	}

	.metric-card {
		position: relative;
		overflow: hidden;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease,
		background-color 220ms ease;
	}

	.metric-card__note {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.26rem 0.62rem;
		border-radius: 9999px;
		background: rgba(84, 121, 179, 0.08);
		color: var(--color-blue-ink);
		font-size: 0.74rem;
		line-height: 1;
	}

	.section-more-link {
		font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", var(--font-sans);
		font-size: 0.98rem;
		font-weight: 700;
		letter-spacing: 0;
		color: var(--color-blue-deep);
		transition: color 180ms ease, transform 180ms ease;
	}

	.section-more-link:hover {
		color: var(--color-blue-ink);
		transform: translateX(2px);
	}

	.metric-card::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(120deg, transparent 30%, rgba(255, 255, 255, 0.72) 48%, transparent 66%);
		transform: translateX(-120%);
		animation: sheen-pass 9s ease-in-out infinite;
		pointer-events: none;
	}

	.metric-card:hover {
		transform: translateY(-3px);
		border-color: rgba(84, 121, 179, 0.26);
		box-shadow: 0 22px 44px rgba(28, 43, 67, 0.1);
	}

	.code-panel {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.75rem;
		background:
			radial-gradient(circle at top right, rgba(84, 121, 179, 0.12), transparent 35%),
			linear-gradient(180deg, #171b23 0%, #11151c 100%);
		box-shadow: 0 28px 60px rgba(15, 23, 42, 0.18);
		animation: panel-float 9s ease-in-out infinite;
	}

	.code-panel::before {
		content: "";
		position: absolute;
		inset: -40% auto -40% -18%;
		width: 42%;
		background: linear-gradient(90deg, transparent, rgba(144, 180, 242, 0.16), transparent);
		transform: rotate(12deg);
		animation: scan-sweep 8.5s ease-in-out infinite;
		pointer-events: none;
	}

	.code-panel__top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.code-panel__dots {
		display: inline-flex;
		gap: 0.35rem;
	}

	.code-panel__dots span {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 9999px;
		background: rgba(255, 255, 255, 0.28);
		animation: dot-pulse 3s ease-in-out infinite;
	}

	.code-panel__dots span:nth-child(2) {
		animation-delay: 0.28s;
	}

	.code-panel__dots span:nth-child(3) {
		animation-delay: 0.56s;
	}

	.code-panel__file {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(226, 232, 240, 0.58);
	}

	.code-panel__body {
		margin: 0;
		padding: 1.4rem 1.25rem 1.6rem;
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: 0.92rem;
		line-height: 1.9;
		color: #d8e1f1;
	}

	.hero-profile {
		position: relative;
		overflow: hidden;
	}

	.hero-profile::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(140deg, rgba(84, 121, 179, 0.06), transparent 34%),
			radial-gradient(circle at top right, rgba(84, 121, 179, 0.12), transparent 38%);
		pointer-events: none;
	}

	.project-card {
		position: relative;
		overflow: hidden;
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease;
	}

	.project-card::before {
		content: "";
		position: absolute;
		inset: auto 1.2rem 0.95rem auto;
		width: 5rem;
		height: 5rem;
		border-radius: 9999px;
		background: radial-gradient(circle, rgba(84, 121, 179, 0.13), transparent 72%);
		opacity: 0;
		transform: translate3d(0, 8px, 0);
		transition: opacity 220ms ease, transform 220ms ease;
		pointer-events: none;
	}

	.project-card:hover {
		transform: translateY(-4px);
		border-color: rgba(84, 121, 179, 0.24);
		box-shadow: 0 24px 50px rgba(28, 43, 67, 0.11);
	}

	.project-card:hover::before {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	.project-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.4rem;
		height: 3.4rem;
		border-radius: 1.25rem;
		border: 1px solid var(--color-slate-200);
		background: linear-gradient(180deg, #fff 0%, #eef3fb 100%);
		font-family: var(--font-mono);
		font-size: 0.86rem;
		letter-spacing: 0.08em;
		color: var(--color-blue-ink);
		transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
	}

	.project-card__icon span {
		font-family: "Microsoft YaHei", "微软雅黑", "PingFang SC", var(--font-sans);
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
	}

	.project-card:hover .project-card__icon {
		transform: translateY(-2px);
		border-color: rgba(84, 121, 179, 0.26);
		box-shadow: 0 10px 26px rgba(84, 121, 179, 0.12);
	}

	.writing-card__visual {
		position: relative;
		min-height: 8.2rem;
		overflow: hidden;
		border-radius: 1.5rem;
		border: 1px solid rgba(148, 163, 184, 0.3);
		background: linear-gradient(180deg, #141922 0%, #0e1219 100%);
		transition: transform 260ms ease, box-shadow 260ms ease;
	}

	.writing-card__grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 1.4rem 1.4rem;
		opacity: 0.4;
		animation: grid-twinkle 11s linear infinite;
	}

	.writing-card__frame {
		position: absolute;
		inset: 1.1rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		align-items: end;
		gap: 0.7rem;
	}

	.writing-card__frame span {
		display: block;
		height: 100%;
		border-radius: 9999px;
		background: linear-gradient(180deg, rgba(84, 121, 179, 0.9), rgba(84, 121, 179, 0.12));
		animation: frame-pulse 4.2s ease-in-out infinite;
		transform-origin: bottom;
	}

	.writing-card__visual[data-visual="2"] .writing-card__frame span:nth-child(1) {
		height: 42%;
	}

	.writing-card__visual[data-visual="2"] .writing-card__frame span:nth-child(2) {
		height: 78%;
	}

	.writing-card__visual[data-visual="2"] .writing-card__frame span:nth-child(3) {
		height: 56%;
	}

	.writing-card__visual[data-visual="1"] .writing-card__frame span:nth-child(1) {
		height: 70%;
	}

	.writing-card__visual[data-visual="1"] .writing-card__frame span:nth-child(2) {
		height: 44%;
	}

	.writing-card__visual[data-visual="1"] .writing-card__frame span:nth-child(3) {
		height: 82%;
	}

	.writing-card__visual[data-visual="3"] .writing-card__frame span:nth-child(1) {
		height: 58%;
	}

	.writing-card__visual[data-visual="3"] .writing-card__frame span:nth-child(2) {
		height: 90%;
	}

	.writing-card__visual[data-visual="3"] .writing-card__frame span:nth-child(3) {
		height: 38%;
	}

	.writing-card:hover .writing-card__visual {
		transform: translateY(-2px);
		box-shadow: 0 16px 30px rgba(15, 23, 42, 0.18);
	}

	.skill-dots {
		display: inline-grid;
		grid-template-columns: repeat(5, 0.4rem);
		gap: 0.35rem;
	}

	.skill-dots i {
		display: block;
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 9999px;
		background: rgba(84, 121, 179, 0.22);
		animation: dot-breathe 3.4s ease-in-out infinite;
	}

	.skill-dots[data-level="5"] i:nth-child(-n + 5),
	.skill-dots[data-level="4"] i:nth-child(-n + 4),
	.skill-dots[data-level="3"] i:nth-child(-n + 3),
	.skill-dots[data-level="2"] i:nth-child(-n + 2),
	.skill-dots[data-level="1"] i:nth-child(-n + 1) {
		background: var(--color-blue-deep);
	}

	.skill-board {
		position: relative;
	}

	.skill-board::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, transparent, rgba(84, 121, 179, 0.06), transparent);
		transform: translateX(-100%);
		animation: board-scan 12s ease-in-out infinite;
		pointer-events: none;
	}

	.skill-column {
		position: relative;
	}

	.skill-column:hover {
		background:
			linear-gradient(180deg, rgba(247, 250, 252, 1) 0%, rgba(242, 247, 255, 1) 100%);
	}

	@keyframes section-rise {
		from {
			opacity: 0;
			transform: translate3d(0, 18px, 0);
		}
		to {
			opacity: 1;
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes grid-drift {
		0% {
			transform: translate3d(0, 0, 0);
		}
		50% {
			transform: translate3d(10px, 8px, 0);
		}
		100% {
			transform: translate3d(0, 0, 0);
		}
	}

	@keyframes orb-shift {
		from {
			transform: translate3d(0, 0, 0) scale(1);
		}
		to {
			transform: translate3d(-18px, -14px, 0) scale(1.06);
		}
	}

	@keyframes panel-float {
		0%, 100% {
			transform: translate3d(0, 0, 0);
		}
		50% {
