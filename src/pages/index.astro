---
import { getCollection, getEntry } from 'astro:content';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Tag from '../components/Tag.astro';
import MainLayout from '../layouts/MainLayout.astro';

const site = await getEntry('site', 'home');

if (!site) {
	throw new Error('Missing site/home content entry.');
}

const projects = (await getCollection('projects'))
	.filter((project) => project.data.featured || site.data.featuredProjects.includes(project.id))
	.sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
	.slice(0, 3);

const posts = (await getCollection('posts', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const categoryLabel: Record<string, string> = {
	ai: 'AI',
	security: 'Security',
	tooling: 'Tooling',
	research: 'Research',
};
---

<MainLayout title={`${site.data.name} · ${site.data.title}`} description={site.data.description} contentClass="max-w-none">
	<section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
		<div class="space-y-6">
			<SectionHeading align="start">Research-minded homepage</SectionHeading>
			<div class="space-y-5">
				<h1 class="text-balance max-w-5xl text-5xl font-semibold tracking-tight text-white md:text-6xl">
					{site.data.heroTitle}
				</h1>
				<p class="eyebrow">{site.data.heroTagline}</p>
				<p class="max-w-3xl text-lg leading-8 text-slate-300">{site.data.description}</p>
			</div>
			<div class="flex flex-wrap gap-3">
				<Button href="/projects">查看项目</Button>
				<Button href="/posts" variant="secondary">阅读文章</Button>
			</div>
			<div class="flex flex-wrap gap-2">
				{site.data.focusAreas.map((item) => <Tag>{item}</Tag>)}
			</div>
		</div>

		<Card as="section" class="space-y-5">
			<div>
				<p class="eyebrow">Profile</p>
				<h2 class="mt-3 text-3xl font-semibold tracking-tight text-white">{site.data.name}</h2>
				<p class="mt-2 text-sm leading-7 text-slate-300">{site.data.subtitle}</p>
			</div>
			<div class="grid gap-3 border-t border-slate-200/10 pt-5 text-sm text-slate-300">
				{site.data.socialLinks.map((link) => (
					<a href={link.url} target="_blank" rel="noreferrer" class="no-underline hover:text-white">
						{link.label}
					</a>
				))}
			</div>
		</Card>
	</section>

	<section class="mt-16">
		<SectionHeading>Featured Projects</SectionHeading>
		<div class="mt-6 grid gap-5 lg:grid-cols-3">
			{projects.map((project) => (
				<Card class="flex h-full flex-col gap-5">
					<div class="space-y-3">
						<p class="eyebrow">{categoryLabel[project.data.category] ?? project.data.category}</p>
						<h2 class="text-2xl font-semibold tracking-tight text-white">{project.data.title}</h2>
						<p class="text-sm leading-7 text-slate-300">{project.data.summary}</p>
					</div>
					<div class="flex flex-wrap gap-2">
						{project.data.stack.map((item) => <Tag>{item}</Tag>)}
					</div>
					<div class="meta-row mt-auto border-t border-slate-200/10 pt-4">
						<FormattedDate date={project.data.publishedDate} />
						{project.data.repoUrl && (
							<a href={project.data.repoUrl} target="_blank" rel="noreferrer" class="no-underline hover:text-white">
								Repository
							</a>
						)}
					</div>
				</Card>
			))}
		</div>
	</section>

	<section class="mt-16">
		<SectionHeading>Latest Writing</SectionHeading>
		<div class="mt-6 grid gap-4">
			{posts.map((post) => (
				<Card as="a" href={`/posts/${post.id}/`} class="grid gap-4 no-underline transition hover:border-cyan-soft/30 hover:bg-slate-100/[0.04] md:grid-cols-[minmax(0,1fr)_10rem] md:items-end">
					<div class="space-y-3">
						<div class="flex flex-wrap gap-2">
							{post.data.tags.map((tag) => <Tag>{tag}</Tag>)}
						</div>
						<h2 class="text-2xl font-semibold tracking-tight text-white">{post.data.title}</h2>
						<p class="text-sm leading-7 text-slate-300">{post.data.description}</p>
					</div>
					<div class="space-y-2 text-sm text-slate-400 md:text-right">
						<FormattedDate date={post.data.date} />
						<p class="font-mono text-[0.78rem] uppercase tracking-[0.18em] text-slate-500">{post.data.readingTime}</p>
					</div>
				</Card>
			))}
		</div>
	</section>

	<section class="mt-16">
		<SectionHeading>Skill Matrix</SectionHeading>
		<div class="mt-6 grid gap-5 lg:grid-cols-4">
			{site.data.skills.map((group) => (
				<Card class="space-y-4">
					<h2 class="eyebrow">{group.category}</h2>
					<ul class="space-y-3 text-sm leading-6 text-slate-300">
						{group.items.map((item) => <li>{item}</li>)}
					</ul>
				</Card>
			))}
		</div>
	</section>
</MainLayout>
