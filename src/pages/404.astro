---
import Button from '../components/Button.astro';
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 · dkx" description="页面不存在。">
	<section class="grid min-h-[60vh] place-items-center">
		<div class="surface-panel max-w-2xl p-10 text-center">
			<div class="tag">404</div>
			<h1 class="mt-6 text-4xl font-semibold tracking-tight text-white">页面不存在</h1>
			<p class="mt-4 text-lg leading-8 text-slate-300">
				你访问的路径没有匹配到当前站点内容，可以返回首页或查看文章、项目列表。
			</p>
			<div class="mt-8 flex flex-wrap justify-center gap-3">
				<Button href="/">Home</Button>
				<Button href="/posts" variant="secondary">Posts</Button>
				<Button href="/projects" variant="secondary">Projects</Button>
			</div>
		</div>
	</section>
</MainLayout>
