---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import MainLayout from './MainLayout.astro';

interface HeadingLink {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	entry: CollectionEntry<'posts'>;
	headings?: HeadingLink[];
}

const { entry, headings = [] } = Astro.props;
const { title, description, date, updatedDate, tags, readingTime } = entry.data;
---

<MainLayout title={title} description={description} contentClass="max-w-none">
	<article class="article-shell mx-auto max-w-6xl">
		<header class="surface-panel article-header">
			<div class="article-header-grid">
				<div class="flex flex-wrap items-center gap-3">
					<span class="tag">Article</span>
					{
						readingTime && (
							<span class="tag" data-tone="neutral">
								{readingTime}
							</span>
						)
					}
					<div class="eyebrow">Structured long-form notes</div>
				</div>

				<div class="article-intro">
					<h1 class="text-balance text-4xl font-semibold tracking-tight text-graphite-900 md:text-5xl">
						{title}
					</h1>
					<p class="article-summary">{description}</p>
				</div>

				<div class="article-meta">
					<div class="meta-row">
						<span>
							Published <FormattedDate date={date} />
						</span>
						{
							updatedDate && (
								<span>
									Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
						{
							headings.length > 1 && (
								<span>{headings.length} sections</span>
							)
						}
					</div>

					{
						tags.length > 0 && (
							<ul class="article-tags" aria-label="Article tags">
								{
									tags.map((tag) => (
										<li>
											<span class="tag" data-tone="soft">
												{tag}
											</span>
										</li>
									))
								}
							</ul>
						)
					}
				</div>
			</div>
		</header>

		{
			headings.length > 1 && (
				<nav class="article-toc article-toc-mobile xl:hidden" aria-label="Table of contents">
					<div class="article-toc-title">On this page</div>
					<ul class="article-toc-list">
						{
							headings.map((heading) => (
								<li>
									<a
										href={`#${heading.slug}`}
										class:list={[
											'article-toc-link',
											heading.depth > 2 && 'is-nested',
										]}
									>
										{heading.text}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			)
		}

		<div class="article-layout">
			<div class="article-main">
				<div class="content-container content-container--article">
					<div class="article-body">
						<slot />
					</div>
				</div>
			</div>

			{
				headings.length > 1 && (
					<aside class="article-sidebar">
						<div class="article-sidebar-inner">
							<div class="article-toc-title">On this page</div>
							<ul class="article-toc-list">
								{
									headings.map((heading) => (
										<li>
											<a
												href={`#${heading.slug}`}
												class:list={[
													'article-toc-link',
													heading.depth > 2 && 'is-nested',
												]}
											>
												{heading.text}
											</a>
										</li>
									))
								}
							</ul>
						</div>
					</aside>
				)
			}
		</div>
	</article>
</MainLayout>
