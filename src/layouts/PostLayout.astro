---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from '../components/FormattedDate.astro';
import MainLayout from './MainLayout.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	date?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
}

const { title, description, pubDate, date, updatedDate, heroImage } = Astro.props;
const publishedAt = pubDate ?? date;
---

<MainLayout title={title} description={description} image={heroImage} contentClass="max-w-none">
	<article class="mx-auto max-w-5xl">
		<header class="surface-panel overflow-hidden">
			<div class="grid gap-8 px-6 py-7 md:px-8 md:py-8">
				<div class="flex flex-wrap items-center gap-3">
					<span class="tag">Research Article</span>
					<div class="eyebrow">Long-form writing</div>
				</div>

				<div class="max-w-3xl space-y-4">
					<h1 class="text-balance text-4xl font-semibold tracking-tight text-white md:text-5xl">
						{title}
					</h1>
					<p class="max-w-2xl text-lg leading-8 text-slate-300">{description}</p>
				</div>

				<div class="meta-row border-t border-slate-200/10 pt-4">
					{publishedAt && <span>Published <FormattedDate date={publishedAt} /></span>}
					{
						updatedDate && (
							<span>
								Updated <FormattedDate date={updatedDate} />
							</span>
						)
					}
				</div>
			</div>

			{
				heroImage && (
					<div class="border-t border-slate-200/10 bg-[#0b0e11] p-3 md:p-4">
						<Image
							width={1280}
							height={720}
							src={heroImage}
							alt=""
							class="aspect-[16/9] w-full object-cover"
						/>
					</div>
				)
			}
		</header>

		<div class="content-container mt-10 md:mt-12">
			<div class="article-body">
				<slot />
			</div>
		</div>
	</article>
</MainLayout>
