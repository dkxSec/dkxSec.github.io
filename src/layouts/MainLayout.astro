---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	mainClass?: string;
	contentClass?: string;
}

const { title, description, image, mainClass, contentClass } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<div class="site-shell">
			<Header />
			<main class:list={['site-main', mainClass]}>
				<div class:list={['site-container', contentClass]}>
					<slot />
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>
