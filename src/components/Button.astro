---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
	variant?: 'primary' | 'secondary';
	as?: 'a' | 'button';
}

const { variant = 'primary', as = 'a', class: className, ...props } = Astro.props;
const Component = as;
---

<Component class:list={['button', className]} data-variant={variant === 'secondary' ? 'secondary' : undefined} {...props}>
	<slot />
</Component>
