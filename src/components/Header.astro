---
import { GITHUB_PROFILE_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-graphite-950/94 backdrop-blur-xl">
	<div class="site-container flex flex-col gap-4 py-4 md:flex-row md:items-center md:justify-between">
		<div class="max-w-xl">
			<a href="/" class="inline-flex items-center gap-3 text-white no-underline">
				<span class="inline-flex h-10 w-10 overflow-hidden rounded-2xl border border-white/14 bg-white/6 shadow-[0_10px_24px_rgba(0,0,0,0.18)]">
					<img src="/avatar.jpg" alt="dkx avatar" class="h-full w-full object-cover" />
				</span>
				<div>
					<div class="text-lg font-semibold tracking-tight text-white">{SITE_TITLE}</div>
					<p class="mt-1 text-sm text-slate-300/80">{SITE_DESCRIPTION}</p>
				</div>
			</a>
		</div>

		<nav aria-label="Primary" class="flex flex-wrap items-center gap-2 md:justify-end">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/posts">Posts</HeaderLink>
			<a href={GITHUB_PROFILE_URL} target="_blank" rel="noreferrer" class="button border-white/20 bg-white/8 text-white hover:border-white/30 hover:bg-white/14">
				GitHub
			</a>
		</nav>
	</div>
</header>
